<?xml version="1.0"?>
<robot name="gripper" xmlns:xacro="http://wiki.ros.org/xacro">

    <xacro:macro name="gripper" params="parent *origin">

        <joint name="joint_3" type="continuous">
            <parent link="${parent}"/>
            <child link="gripper_base_link"/>
            <xacro:insert_block name="origin" />
            <axis xyz="0 0 1" />
            <limit lower="-2.7227" upper="-0.83776" effort="100" velocity="100.0" />
        </joint>

        <link name="gripper_base_link">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <box size="0.1 0.6 0.05"/>
                </geometry>
                <material name="gripper_base_link">
                    <color rgba="1 1 0 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <box size="0.1 0.6 0.05"/>
                </geometry>
            </collision>  
            <inertial>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <mass value="1.0"/>
                <inertia 
                    ixx="0.00015" ixy="1e-05" ixz="0" 
                    iyy="0.0002" iyz="0" izz="0.0002"/>
            </inertial>
        </link>   

        <joint name="joint_right_finger" type="prismatic">
            <parent link="gripper_base_link"/>
            <child link="right_finger"/>
            <origin xyz="0 -0.25 0" rpy="0 0 0"/>
            <axis xyz="0 1 0" />
            <limit lower="-0.25" upper="0.25" effort="500" velocity="100.0" />
        </joint>

        <link name="right_finger">
            <visual>
                <origin xyz="0 0 -0.175" rpy="0 0 0"/>
                <geometry>
                    <box size="0.075 0.075 0.3"/>
                </geometry>
                <material name="right_finger">
                    <color rgba="0 1 1 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 -0.175" rpy="0 0 0"/>
                <geometry>
                    <box size="0.075 0.075 0.3"/>
                </geometry>
            </collision>  
            <inertial>
                <mass value="1.0"/>
                <origin xyz="0 0 -0.175" rpy="0 0 0"/>
                <inertia 
                    ixx="0.00015" ixy="1e-05" ixz="0" 
                    iyy="0.0002" iyz="0" izz="0.0002"/>
            </inertial>
        </link> 

        <joint name="joint_left_finger" type="prismatic">
            <parent link="gripper_base_link"/>
            <child link="left_finger"/>
            <origin xyz="0 0.25 0" rpy="0 0 0"/>
            <axis xyz="0 1 0" />
            <limit lower="-0.25" upper="0.25" effort="500" velocity="100.0" />
        </joint>

        <link name="left_finger">
            <visual>
                <origin xyz="0 0 -0.175" rpy="0 0 0"/>
                <geometry>
                    <box size="0.075 0.075 0.3"/>
                </geometry>
                <material name="left_finger">
                    <color rgba="0 1 1 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 -0.175" rpy="0 0 0"/>
                <geometry>
                    <box size="0.075 0.075 0.3"/>
                </geometry>
            </collision>  
            <inertial>
                <mass value="1.0"/>
                <origin xyz="0 0 -0.175" rpy="0 0 0"/>
                <inertia 
                    ixx="0.00015" ixy="1e-05" ixz="0" 
                    iyy="0.0002" iyz="0" izz="0.0002"/>
            </inertial>
        </link> 

       
    </xacro:macro>
</robot>