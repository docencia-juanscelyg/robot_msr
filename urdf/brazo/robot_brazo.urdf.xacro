<?xml version="1.0"?>
<robot name="robot" xmlns:xacro="http://wiki.ros.org/xacro">

<xacro:include filename="$(find robot_msr)/urdf/brazo/robot_gripper.urdf.xacro"/>

  <!-- BRAZO XACRO -->
  <xacro:macro name="robot_brazo" params="parent *origin">

    <joint name="base_joint" type="fixed">
        <parent link="${parent}"/>
        <child link="brazo_base_link"/>
        <xacro:insert_block name="origin" />
    </joint>

    <link name="brazo_base_link">
      <inertial>
        <mass value="10.0"/>
        <inertia 
            ixx="0.00015" ixy="1e-05" ixz="0" 
            iyy="0.0002" iyz="0" izz="0.0002"/>
      </inertial>
      <visual>
      <origin xyz="0 0 1" rpy="0 0 0"/>
        <geometry>
          <cylinder length="2" radius="0.2"/>
        </geometry>
      </visual>
      <collision>
      <origin xyz="0 0 1" rpy="0 0 0"/>
        <geometry>
          <cylinder length="1" radius="0.2"/>
        </geometry>
      </collision>
    </link>

    <joint name="joint_0" type="continuous">
      <parent link="brazo_base_link"/>
      <child link="eslabon_1"/>
      <origin xyz="0 0 2" rpy="0 0 0"/>
      <axis xyz="0 0 1" />
      <limit lower="-3.141592" upper="3.141592" effort="1000" velocity="100.0" />
    </joint>

    <link name="eslabon_1">
        <visual>
            <origin xyz="1 0 0" rpy="0 1.57 0"/>
            <geometry>
                <cylinder length="2" radius="0.2"/>
            </geometry>
            <material name="eslabon_1">
                <color rgba="0 1 0 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="1 0 0" rpy="0 1.57 0"/>
            <geometry>
                <cylinder length="2" radius="0.2"/>
            </geometry>
        </collision>  
        <inertial>
            <mass value="5.0"/>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <inertia 
                ixx="0.00015" ixy="1e-05" ixz="0" 
                iyy="0.0002" iyz="0" izz="0.0002"/>
        </inertial>
    </link> 

    <joint name="joint_1" type="continuous">
      <parent link="eslabon_1"/>
      <child link="eslabon_2"/>
      <origin xyz="2 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1" />
      <limit lower="-3.141592" upper="3.141592" effort="1000" velocity="100.0" />
    </joint>

    <link name="eslabon_2">
        <visual>
            <origin xyz="1 0 0" rpy="0 1.57 0"/>
            <geometry>
                <cylinder length="2" radius="0.2"/>
            </geometry>
            <material name="eslabon_2">
                <color rgba="0 0 1 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="1 0 0" rpy="0 1.57 0"/>
            <geometry>
                <cylinder length="2" radius="0.2"/>
            </geometry>
        </collision>  
        <inertial>
            <mass value="5.0"/>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <inertia 
                ixx="0.00015" ixy="1e-05" ixz="0" 
                iyy="0.0002" iyz="0" izz="0.0002"/>
        </inertial>
    </link> 

    <joint name="joint_2" type="prismatic">
      <parent link="eslabon_2"/>
      <child link="eslabon_3"/>
      <origin xyz="2 0 -1" rpy="0 0 0"/>
      <axis xyz="0 0 1" />
      <limit lower="-3.141592" upper="3.141592" effort="1000" velocity="100.0" />
    </joint>

    <link name="eslabon_3">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="3" radius="0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="3" radius="0.1"/>
            </geometry>
        </collision>  
        <inertial>
            <mass value="5.0"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia 
                ixx="0.00015" ixy="1e-05" ixz="0" 
                iyy="0.0002" iyz="0" izz="0.0002"/>
        </inertial>
    </link> 

    <xacro:gripper parent="eslabon_3">
      <origin xyz="0 0 -1.5" rpy="0 0 0"/>
    </xacro:gripper>

  </xacro:macro>
</robot>