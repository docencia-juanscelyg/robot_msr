<?xml version="1.0"?>
<robot name="robot" xmlns:xacro="http://wiki.ros.org/xacro">

  <!-- WHEEL XACRO -->
  <xacro:macro name="robot_rueda" params="prefix parent *origin">

    <!--TIRE -->
    <joint name="${prefix}wheel_joint" type="continuous">
        <xacro:insert_block name="origin" />
        <parent link="${parent}"/>
        <child link="${prefix}wheel_link"/>
        <axis xyz="0 0 1" rpy="0 0 0" />
        <limit effort="5000" velocity="100"/>
        <dynamics damping="0.05" friction="0.1"/>
    </joint>

    <link name="${prefix}wheel_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="10.0"/>
            <inertia ixx="0.02975" ixy="0" ixz="0" iyy="0.03087" iyz="0" izz="0.00191"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.2" radius="0.3"/>
            </geometry>
            <material name="${prefix}wheel_material">
                <color rgba="0.1 0.1 0.1 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.2" radius="0.3"/>
            </geometry>
            <surface>
                <friction>
                    <ode>
                        <mu>1.000000</mu>
                        <mu2>1.000000</mu2>
                        <fdir1>0.000000 0.000000 1.000000</fdir1>
                        <slip1>0.0050000</slip1>
                        <slip2>0.0050000</slip2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </link>

    <!-- Transmission is important to link the joints and the controller (see config/rover_controller.yaml)-->
    <transmission name="${prefix}_wheel_joint_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="${prefix}wheel_joint" >
            <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
        </joint>
        <actuator name="${prefix}wheel_joint_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <gazebo reference="${prefix}wheel_link">
        <mu1>5</mu1>
        <mu2>5</mu2>
        <!--kp>2.75e6</kp>
        <kd>8.25e1</kd>
        <fdir1>0 0 0</fdir1>
        <maxContacts>4</maxContacts-->
    </gazebo>

    </xacro:macro>
</robot>